[
  {
    "id": "vcpkg",
    "display_name": "vcpkg",
    "built_in": true,
    "install_cmd": null,
    "version_cmd": "vcpkg --version",
    "version_exe": "vcpkg",
    "cache_detect_cmd": null,
    "cache_default_path": "{home}\\AppData\\Local\\vcpkg\\downloads",
    "cache_env_var": "VCPKG_DOWNLOADS",
    "cache_set_cmd_template": null,
    "data_detect_cmd": null,
    "data_default_path": null,
    "data_env_var": null,
    "data_set_cmd_template": null,
    "proxy_detect_cmd": "powershell -Command \"[Environment]::GetEnvironmentVariable('http_proxy','User')\"",
    "proxy_set_cmd_template": "powershell -Command \"`$u='{url}'; [Environment]::SetEnvironmentVariable('http_proxy', `$u, 'User'); [Environment]::SetEnvironmentVariable('https_proxy', `$u, 'User')\"",
    "mirror_options": [
      {
        "mirror_type": "official",
        "name": "官方源（默认）",
        "url": ""
      },
      {
        "mirror_type": "sjtu",
        "name": "上海交通大学 vcpkg 镜像",
        "url": "clear;x-azurl=https://mirror.sjtu.edu.cn/vcpkg"
      }
    ],
    "mirror_cmd_template": "powershell -Command \"`$val='{url}'; if (`$val -ne '') { [Environment]::SetEnvironmentVariable('X_VCPKG_ASSET_SOURCES', `$val, 'User') } else { [Environment]::SetEnvironmentVariable('X_VCPKG_ASSET_SOURCES', `$null, 'User') }\"",
    "mirror_detect_cmd": "powershell -Command \"[Environment]::GetEnvironmentVariable('X_VCPKG_ASSET_SOURCES', 'User')\""
  }
]
