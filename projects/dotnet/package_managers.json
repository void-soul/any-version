[
  {
    "id": "nuget",
    "display_name": "NuGet",
    "built_in": true,
    "install_cmd": null,
    "version_cmd": "dotnet nuget --version",
    "version_exe": "dotnet",
    "cache_detect_cmd": null,
    "cache_default_path": "{home}\\.nuget\\packages",
    "cache_env_var": "NUGET_PACKAGES",
    "cache_set_cmd_template": null,
    "data_detect_cmd": null,
    "data_default_path": null,
    "data_env_var": null,
    "data_set_cmd_template": null,
    "proxy_detect_cmd": null,
    "proxy_set_cmd_template": null,
    "pkg_list_cmd": null,
    "pkg_list_format": null,
    "pkg_upgrade_cmd_template": null,
    "pkg_homepage_template": "https://www.nuget.org/packages/{pkg}",
    "cache_config_source": {
      "parser_type": "xml",
      "env_vars": [
        "NUGET_PACKAGES"
      ],
      "paths": [
        "{home}\\AppData\\Roaming\\NuGet\\NuGet.Config"
      ],
      "keys": [
        "<add\\s+key\\s*=\\s*\"globalPackagesFolder\"\\s+value\\s*=\\s*\"([^\"]+)\""
      ],
      "write_keys": [
        {
          "key": "globalPackagesFolder",
          "value_suffix": "packages"
        },
        {
          "key": "httpCachePath",
          "value_suffix": "v3-cache"
        },
        {
          "key": "pluginsCachePath",
          "value_suffix": "plugins-cache"
        }
      ]
    }
  }
]
