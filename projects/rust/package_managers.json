[
  {
    "id": "cargo",
    "display_name": "Cargo",
    "built_in": true,
    "install_cmd": null,
    "version_cmd": "cargo --version",
    "version_exe": "cargo",
    "cache_detect_cmd": null,
    "cache_default_path": "{home}\\.cargo",
    "cache_env_var": "CARGO_HOME",
    "cache_set_cmd_template": null,
    "data_detect_cmd": null,
    "data_default_path": null,
    "data_env_var": null,
    "data_set_cmd_template": null,
    "proxy_detect_cmd": null,
    "proxy_set_cmd_template": null,
    "pkg_list_cmd": null,
    "pkg_homepage_template": "https://crates.io/crates/{pkg}",
    "mirror_cmd_template": null,
    "mirror_config_file": "{home}\\.cargo\\config.toml",
    "mirror_detect_file_regex": "registry\\s*=\\s*\"([^\"]+)\"",
    "mirror_config_desc": "%USERPROFILE%\\.cargo\\config.toml（Cargo 镜像源配置）",
    "mirror_options": [
      {
        "mirror_type": "official",
        "name": "官方源 (crates.io)",
        "url": "https://github.com/rust-lang/crates.io-index",
        "config_content": null
      },
      {
        "mirror_type": "rsproxy",
        "name": "Rsproxy 镜像",
        "url": "https://rsproxy.cn",
        "config_content": "[source.crates-io]\nreplace-with = 'rsproxy'\n\n[source.rsproxy]\nregistry = \"https://rsproxy.cn/crates.io-index\"\n\n[source.rsproxy-sparse]\nregistry = \"sparse+https://rsproxy.cn/index/\"\n\n[net]\ngit-fetch-with-cli = true\n"
      },
      {
        "mirror_type": "tsinghua",
        "name": "清华大学镜像",
        "url": "https://mirrors.tuna.tsinghua.edu.cn/git/crates.io-index",
        "config_content": "[source.crates-io]\nreplace-with = 'tsinghua'\n\n[source.tsinghua]\nregistry = \"https://mirrors.tuna.tsinghua.edu.cn/git/crates.io-index\"\n"
      }
    ]
  }
]
