{
  "id": "redis",
  "display_name": "Redis",
  "category": "service",
  "official_website": "https://redis.io",
  "simple_mode": false,
  "bin_dirs": [
    ""
  ],
  "has_cache": false,
  "cache_detect_cmd": null,
  "cache_default_path": null,
  "has_mirror": false,
  "mirror_options": null,
  "has_pkg": false,
  "pkg_manager": null,
  "pkg_homepage_template": null,
  "is_service": true,
  "default_port": 6379,
  "data_dir": null,
  "log_dir": null,
  "config_file": "redis.windows.conf",
  "config_file_candidates": [
    "{install_root}\\redis.windows.conf",
    "{install_root}\\redis.conf"
  ],
  "start_cmd": "\"{install_root}\\redis-server.exe\" \"{config_file}\" --port {port} --dir \"{data_dir}\" --logfile \"{log_dir}\\redis.log\"",
  "stop_cmd": "\"{install_root}\\redis-cli.exe\" -p {port} shutdown nosave",
  "service_process_exes": [
    "redis-server",
    "redisService",
    "memurai"
  ],
  "service_names": [
    "^Redis$",
    "^Redis-Service$",
    "^Memurai(-\\d+)?$"
  ],
  "service_start_mode": "detached",
  "service_allow_force_kill": false,
  "service_auto_create_dirs": true,
  "version_cmd": "redis-server --version",
  "version_exe": "redis-server",
  "download_file_ext": "zip",
  "version_url_prefix_map": {
    "7.": "https://github.com/redis-windows/redis-windows/releases/download/{version}/Redis-{version}-Windows-x64-msys2.zip",
    "5.": "https://github.com/tporadowski/redis/releases/download/v{version}/Redis-x64-{version}.zip",
    "4.": "https://github.com/tporadowski/redis/releases/download/v{version}/Redis-x64-{version}.zip",
    "3.": "https://github.com/MSOpenTech/redis/releases/download/win-{version}/Redis-x64-{version}.zip"
  },
  "data_dirs": [
    {
      "id": "data",
      "display_name": "Redis 数据目录",
      "kind": "data",
      "possible_paths": [
        "{install_root}\\data"
      ],
      "default_path": "{install_root}\\data",
      "supports_direct": true,
      "auto_create": true,
      "required_for_start": false
    },
    {
      "id": "log",
      "display_name": "Redis 日志目录",
      "kind": "log",
      "possible_paths": [
        "{install_root}\\logs",
        "{install_root}\\log"
      ],
      "default_path": "{install_root}\\logs",
      "supports_direct": true,
      "auto_create": true,
      "required_for_start": false
    }
  ]
}
