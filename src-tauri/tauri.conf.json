{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyVersion",
  "version": "3.0.3",
  "identifier": "com.voidsoul.anyversion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9999",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AnyVersion 开发环境管理器",
        "width": 1150,
        "height": 780,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../ai-tools/*.json",
      "../ai-tools/*/*.json",
      "../projects/*/*.json"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/void-soul/any-version/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkyOEI4ODhCQkMxQTUxREQ0MQ0KUldSQjNWRWF2SXVJaXlZdk1Sd0g0cWRPNXhzU3Z4WGNORzZ5N3pCNDBvRUxxbUY5ditsTjJmZVo="
    }
  }
}
