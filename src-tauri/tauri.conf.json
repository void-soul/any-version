{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyVersion",
  "version": "2.4.6",
  "identifier": "com.voidsoul.anyversion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9999",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AnyVersion 开发环境管理器",
        "width": 1150,
        "height": 780,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../projects.json"
    ]
  }
}
