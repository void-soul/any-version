[
  {
    "id": "nodejs",
    "display_name": "Node.js",
    "category": "language",
    "official_website": "https://nodejs.org",
    "env_vars": [],
    "find_rules": [
      {
        "pattern": {
          "type": "env_bin",
          "env_var": "NVM_HOME",
          "bin_sub": "",
          "exe_name": "node.exe"
        },
        "source_label": "nvm-windows",
        "priority": 10,
        "root_offset": 0
      },
      {
        "pattern": {
          "type": "env_bin",
          "env_var": "VOLTA_HOME",
          "bin_sub": "bin",
          "exe_name": "node.exe"
        },
        "source_label": "Volta",
        "priority": 10,
        "root_offset": 0
      },
      {
        "pattern": {
          "type": "path_contains",
          "path_key": "scoop\\apps\\nodejs",
          "exe_name": "node.exe"
        },
        "source_label": "Scoop",
        "priority": 40,
        "root_offset": 1
      },
      {
        "pattern": {
          "type": "path_contains",
          "path_key": "chocolatey\\lib\\nodejs",
          "exe_name": "node.exe"
        },
        "source_label": "Chocolatey",
        "priority": 40,
        "root_offset": 1
      },
      {
        "pattern": {
          "type": "fixed_path",
          "path": "C:\\msys64\\mingw64\\bin",
          "exe_name": "node.exe"
        },
        "source_label": "MSYS2",
        "priority": 60,
        "root_offset": 0
      },
      {
        "pattern": {
          "type": "fixed_path",
          "path": "C:\\Program Files\\nodejs",
          "exe_name": "node.exe"
        },
        "source_label": "Program Files",
        "priority": 70,
        "root_offset": 0
      },
      {
        "pattern": {
          "type": "path_contains",
          "path_key": "\\nodejs\\",
          "exe_name": "node.exe"
        },
        "source_label": "系统 PATH",
        "priority": 80,
        "root_offset": 1
      }
    ],
    "has_cache": false,
    "cache_detect_cmd": null,
    "cache_default_path": null,
    "has_mirror": false,
    "mirror_options": null,
    "has_pkg": false,
    "pkg_manager": null,
    "pkg_homepage_template": null,
    "is_service": false,
    "default_port": null,
    "data_dir": null,
    "log_dir": null,
    "config_file": null,
    "start_cmd": null,
    "stop_cmd": null,
    "download_url_template": "https://nodejs.org/dist/v{version}/node-v{version}-win-x64.zip",
    "remote_versions_url": "https://nodejs.org/dist/index.json",
    "user_configurable_vars": [
      { "name": "NODE_OPTIONS", "desc": "传递 V8 / Node CLI 标志，无需改启动脚本", "placeholder": "--max-old-space-size=4096 --inspect=0.0.0.0:9229" },
      { "name": "NODE_ENV", "desc": "运行环境标识，大量库据此切换行为（压缩、缓存、日志等）", "placeholder": "development", "options": ["development", "production", "test"] },
      { "name": "NODE_NO_WARNINGS", "desc": "设为 1 静默所有进程警告", "placeholder": "1", "type": "boolean" },
      { "name": "NODE_DEBUG", "desc": "启用内置模块调试输出（, 分隔模块名）", "placeholder": "http,net,fs" },
      { "name": "DEBUG", "desc": "debug 库通配符过滤，生态系统广泛支持", "placeholder": "app:*" },
      { "name": "NODE_V8_COVERAGE", "desc": "输出 V8 代码覆盖率 JSON 到指定目录", "placeholder": "./coverage" },
      { "name": "NODE_EXTRA_CA_CERTS", "desc": "追加可信 CA 证书文件 (PEM)", "placeholder": "/path/to/ca.pem" },
      { "name": "UV_THREADPOOL_SIZE", "desc": "libuv 线程池大小，影响文件 I/O / DNS 并发（默认 4，上限 1024）", "placeholder": "16" },
      { "name": "FORCE_COLOR", "desc": "强制启用彩色输出（chalk 等库使用）", "placeholder": "1", "type": "boolean" },
      { "name": "NO_COLOR", "desc": "标准约定：设此变量禁用所有颜色输出", "placeholder": "1", "type": "boolean" },
      { "name": "NODE_TLS_REJECT_UNAUTHORIZED", "desc": "设 0 禁用 TLS 证书校验（仅开发用）", "placeholder": "0", "type": "boolean" },
      { "name": "NODE_COMPILE_CACHE", "desc": "Node 22+ 字节码编译缓存目录，加速冷启动", "placeholder": "./.node-cache" },
      { "name": "HTTP_PROXY", "desc": "出站 HTTP 代理（需配合代理库生效）", "placeholder": "http://127.0.0.1:7890" },
      { "name": "HTTPS_PROXY", "desc": "出站 HTTPS 代理", "placeholder": "http://127.0.0.1:7890" },
      { "name": "NO_PROXY", "desc": "不走代理的域名/IP（, 分隔）", "placeholder": "localhost,127.0.0.1" }
    ],
    "package_managers": [
      {
        "id": "npm",
        "display_name": "npm",
        "built_in": true,
        "install_cmd": null,
        "version_cmd": "npm --version",
        "version_exe": "npm",
        "cache_detect_cmd": "npm config get cache",
        "cache_default_path": "{home}\\AppData\\Local\\npm-cache",
        "cache_env_var": "NPM_CONFIG_CACHE",
        "cache_set_cmd_template": "npm config set cache \"{path}\"",
        "data_detect_cmd": null,
        "data_default_path": null,
        "data_env_var": null,
        "data_set_cmd_template": null,
        "proxy_detect_cmd": "npm config get proxy",
        "proxy_set_cmd_template": "npm config set proxy {url}",
        "pkg_list_cmd": "npm list -g --depth=0",
        "mirror_cmd_template": "npm config set registry {url}",
        "mirror_options": [
          {
            "mirror_type": "official",
            "name": "官方源",
            "url": "https://registry.npmjs.org/"
          },
          {
            "mirror_type": "aliyun",
            "name": "阿里云/淘宝镜像",
            "url": "https://registry.npmmirror.com/"
          },
          {
            "mirror_type": "tencent",
            "name": "腾讯云镜像",
            "url": "https://mirrors.cloud.tencent.com/npm/"
          }
        ]
      },
      {
        "id": "yarn",
        "display_name": "Yarn",
        "install_cmd": "npm install -g yarn",
        "upgrade_cmd": null,
        "latest_version_cmd": "npm view yarn version",
        "version_cmd": "yarn --version",
        "version_exe": "yarn",
        "cache_detect_cmd": "yarn cache dir",
        "pkg_list_cmd": "yarn global list",
        "mirror_cmd_template": "yarn config set registry {url}",
        "mirror_options": [
          {
            "mirror_type": "official",
            "name": "官方源",
            "url": "https://registry.yarnpkg.com/"
          },
          {
            "mirror_type": "aliyun",
            "name": "阿里云",
            "url": "https://registry.npmmirror.com/"
          }
        ],
        "cache_default_path": "{home}\\.cache\\yarn",
        "cache_env_var": "YARN_CACHE_FOLDER",
        "cache_set_cmd_template": "yarn config set cache-folder \"{path}\"",
        "data_detect_cmd": null,
        "data_default_path": null,
        "data_env_var": null,
        "data_set_cmd_template": null,
        "proxy_detect_cmd": "yarn config get proxy",
        "proxy_set_cmd_template": "yarn config set proxy {url}"
      },
      {
        "id": "pnpm",
        "display_name": "pnpm",
        "install_cmd": "npm install -g pnpm",
        "upgrade_cmd": null,
        "latest_version_cmd": "npm view pnpm version",
        "version_cmd": "pnpm --version",
        "version_exe": "pnpm",
        "cache_detect_cmd": "pnpm store path",
        "pkg_list_cmd": "pnpm list -g --depth=0",
        "mirror_cmd_template": "pnpm config set registry {url}",
        "mirror_options": [
          {
            "mirror_type": "official",
            "name": "官方源",
            "url": "https://registry.npmjs.org/"
          },
          {
            "mirror_type": "aliyun",
            "name": "阿里云",
            "url": "https://registry.npmmirror.com/"
          }
        ],
        "cache_default_path": "{home}\\.local\\share\\pnpm\\store",
        "cache_env_var": "PNPM_STORE_DIR",
        "cache_set_cmd_template": "pnpm config set store-dir \"{path}\"",
        "data_detect_cmd": null,
        "data_default_path": null,
        "data_env_var": null,
        "data_set_cmd_template": null,
        "proxy_detect_cmd": "pnpm config get proxy",
        "proxy_set_cmd_template": "pnpm config set proxy {url}"
      }
    ],
    "download_file_ext": "zip",
    "remote_versions_config": {
      "type": "json_api",
      "response_type": "array",
      "version_field": "version",
      "version_transform": "trim_prefix:v",
      "extra_field": "lts",
      "extra_format": "lts_label",
      "max_count": 0
    },
    "version_cmd": "node --version",
    "version_exe": "node"
  },
