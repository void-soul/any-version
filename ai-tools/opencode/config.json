{
  "id": "opencode",
  "displayName": "OpenCode",
  "category": "cli-code",
  "website": "https://opencode.ai",
  "apiProtocol": "openai",
  "supportModel": true,
  "supportFallbackModel": false,

  "resumeCmd": "opencode -s {session_id}",
  "continueCmd": null,
  "cacheDirs": [".opencode"],
  "pkgManager": "npm",
  "pkgName": "opencode-ai",
  "configFile": {
    "path": "~/.config/opencode/opencode.json",
    "format": "jsonc",
      "write": {
        "provider.anyversion.name": "anyversion",
        "provider.anyversion.npm": "@ai-sdk/openai-compatible",
        "provider.anyversion.options.baseURL": "baseUrl",
        "provider.anyversion.options.apiKey": "apiKey",
        "provider.anyversion.models.{model_name}.name": "modelName",
        "model": "model"
      }
  },
  "modelFormat": {
    "prefix": "anyversion/",
    "extractLast": true
  },
  "sessions": {
    "type": "opencode_style",
    "dirs": ["~/.config/opencode", "~/.opencode"]
  },
  "skillsDir": "~/.opencode/skills",
  "skillsDirXdg": "~/.config/opencode/skills"
}
