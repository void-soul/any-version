{
  "id": "mimocode",
  "displayName": "MiMo Code",
  "category": "cli-code",
  "website": "https://mimo.xiaomi.com/zh/mimocode/config-files",
  "apiProtocol": "openai",
  "supportModel": true,
  "modelArg": "-m",
  "supportFallbackModel": true,
  "fallbackModelArg": "--small-model",
  "resumeCmd": null,
  "continueCmd": null,
  "cacheDirs": [".local/share/mimocode"],
  "pkgManager": "npm",
  "pkgName": "@mimo-ai/cli",
  "configFile": {
    "path": "~/.config/mimocode/mimocode.json",
    "format": "json",
    "schema": "https://mimo.xiaomi.com/config.json",
    "write": {
      "providers.anyversion.name": "anyversion",
      "providers.anyversion.type": "openai-compatible",
      "providers.anyversion.options.baseURL": "baseUrl",
      "providers.anyversion.options.apiKey": "apiKey",
      "providers.anyversion.npm": "@ai-sdk/openai-compatible",
      "defaultModel": "model"
    }
  },
  "modelFormat": {
    "prefix": "anyversion/",
    "extractLast": true
  },
  "sessions": {
    "type": "mimocode_style",
    "dirs": ["~/.config/mimocode", "~/.mimo-code"]
  },
  "skillsDir": "~/.mimocode/skills"
}
