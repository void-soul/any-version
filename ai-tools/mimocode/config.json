{
  "id": "mimocode",
  "displayName": "MiMo Code",
  "category": "cli-code",
  "website": "https://mimo.xiaomi.com/zh/mimocode/config-files",
  "apiProtocol": "openai",
  "supportModel": true,
  "supportFallbackModel": true,

  "resumeCmd": null,
  "continueCmd": null,
  "cacheDirs": [".local/share/mimocode"],
  "pkgManager": "npm",
  "pkgName": "@mimo-ai/cli",
  "configFile": {
    "path": "~/.config/mimocode/mimocode.json",
    "format": "json",
    "schema": "https://mimo.xiaomi.com/mimocode/config.json",
      "write": {
        "provider.anyversion.npm": "@ai-sdk/openai-compatible",
        "provider.anyversion.name": "anyversion",
        "provider.anyversion.options.baseURL": "baseUrl",
      "provider.anyversion.options.apiKey": "apiKey",
      "model": "model",
      "small_model": "fallbackModel",
      "provider.anyversion.models.{model_name}.name": "modelName"
    }
  },
  "modelFormat": {
    "prefix": "anyversion/",
    "extractLast": true
  },
  "sessions": {
    "type": "mimocode_style",
    "dirs": ["~/.config/mimocode", "~/.mimo-code"]
  },
  "skillsDir": "~/.mimocode/skills"
}
