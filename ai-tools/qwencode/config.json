{
  "id": "qwencode",
  "displayName": "Qwen Code",
  "category": "cli-code",
  "website": "https://github.com/QwenLM/qwen-code",
  "apiProtocol": "openai",
  "supportModel": true,
  "supportFallbackModel": false,

  "resumeCmd": null,
  "continueCmd": null,
  "cacheDirs": [".qwen-code", ".qwen"],
  "pkgManager": "npm",
  "pkgName": "@qwen-code/qwen-code",
  "configFile": {
    "path": "~/.qwen/settings.json",
    "format": "json",
    "write": {
      "model.name": "model",
      "env.OPENAI_API_KEY": "apiKey",
      "env.OPENAI_BASE_URL": "baseUrl"
    }
  },
  "sessions": {
    "type": "none"
  },
  "skillsDir": "~/.qwen/skills"
}
