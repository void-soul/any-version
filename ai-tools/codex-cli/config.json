{
  "id": "codex-cli",
  "displayName": "Codex CLI",
  "avatar": "⚡",
  "nickname": "Codex",
  "category": "cli-code",
  "website": "https://github.com/openai/codex",
  "apiProtocol": "openai",
  "supportModel": true,
  "supportFallbackModel": false,

  "supportsOpenai": true,
  "supportsAnthropic": false,
  "supportsGoogle": false,
  "builtinModels": [],
  "supportsOptimizer": true,
  "supportsRectifier": true,

  "resumeCmd": null,
  "continueCmd": "codex resume --last",
  "dispatchCmd": "codex exec --json --full-auto \"{prompt}\"",
  "dispatchResumeCmd": "codex exec --json --full-auto resume {session_id} \"{prompt}\"",
  "runner": "codex-json",
  "promptMode": "arg",
  "cacheDirs": [".codex"],
  "pkgManager": "npm",
  "pkgName": "@openai/codex",
  "configFile": {
    "path": "~/.codex/config.toml",
    "format": "toml",
    "write": {
      "model": "model",
      "model_provider": "anyversion",
      "model_providers.anyversion.name": "AnyVersion",
      "model_providers.anyversion.base_url": "baseUrl",
      "model_providers.anyversion.env_key": "OPENAI_API_KEY",
      "env.OPENAI_API_KEY": "apiKey"
    }
  },
  "sessions": {
    "type": "jsonl",
    "dirs": ["~/.codex/sessions.jsonl"]
  },
  "skillsDir": "~/.codex/skills"
}
