{
  "id": "codex-cli",
  "displayName": "Codex CLI",
  "category": "cli-code",
  "website": "https://github.com/openai/codex",
  "apiProtocol": "openai",
  "supportModel": true,
  "supportFallbackModel": false,

  "resumeCmd": null,
  "continueCmd": "codex resume --last",
  "cacheDirs": [".codex"],
  "pkgManager": "npm",
  "pkgName": "@openai/codex",
  "configFile": {
    "path": "~/.codex/config.toml",
    "format": "toml",
    "write": {
      "model": "model",
      "openai_api_key": "apiKey",
      "openai_base_url": "baseUrl"
    }
  },
  "sessions": {
    "type": "jsonl",
    "dirs": ["~/.codex/sessions.jsonl"]
  },
  "skillsDir": "~/.codex/skills"
}
